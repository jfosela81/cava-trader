# Variables de entorno — copiar a .env.local y rellenar los valores

# Twelve Data — https://twelvedata.com (free tier: 800 req/day)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Supabase — reutilizar proyecto existente del BTC trader
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Bot configuration
BOT_INITIAL_CAPITAL=10000
BOT_MAX_TRADES_PER_DAY=2
BOT_STOP_LOSS_PCT=0.3
BOT_TAKE_PROFIT_PCT=1.0
BOT_TIMEZONE=Europe/Madrid

# Internal cron secret (para proteger los endpoints de cron)
CRON_SECRET=generate_a_random_secret_here
